 "css": "@media print {\r\n    html, body {\r\n        margin: 0;\r\n        padding: 0;\r\n        background: none !important;\r\n        -webkit-print-color-adjust: exact;\r\n        print-color-adjust: exact;\r\n        width: 210mm;\r\n        height: 297mm;\r\n        overflow: hidden;\r\n        transform: scale(1.1);\r\n        transform-origin: top left;\r\n    }\r\n\r\n    @page {\r\n        size: A4;\r\n        margin: 0; /* no padding or margin on print */\r\n    }\r\n\r\n    /* Main container */\r\n    .container {\r\n        width: 100%;\r\n        max-width: 210mm;\r\n        min-height: 297mm;\r\n        box-sizing: border-box;\r\n        margin: 0 auto;\r\n        padding: 0 !important;\r\n        border: 1px solid #000; /* keep border only */\r\n        background: none !important;\r\n        page-break-before: avoid;\r\n        page-break-after: avoid;\r\n        page-break-inside: avoid;\r\n        break-before: avoid-page;\r\n        break-after: avoid-page;\r\n        break-inside: avoid-page;\r\n    }\r\n\r\n    /* Prevent splitting of main sections */\r\n    .header,\r\n    .employee-net-section,\r\n    .pf-section,\r\n    .earnings-deductions,\r\n    .final-payable,\r\n    .amount-words,\r\n    .footer {\r\n        display: block !important;\r\n        page-break-inside: avoid !important;\r\n        break-inside: avoid-page !important;\r\n        width: 100%;\r\n    }\r\n\r\n    /* Tables */\r\n    table, tr, td, th, tbody, thead, tfoot {\r\n        border-collapse: collapse !important;\r\n        page-break-inside: avoid !important;\r\n        break-inside: avoid !important;\r\n    }\r\n\r\n    /* Font tuning */\r\n    body, td, th, span {\r\n        \r\n        color: #000 !important;\r\n        line-height: 1.3 !important;\r\n        vertical-align: top !important;\r\n    }\r\n\r\n    /* Remove all shadows and colors */\r\n    .net-pay-card,\r\n    .final-payable,\r\n    .earnings-deductions {\r\n        box-shadow: none !important;\r\n        background: none !important;\r\n        border: 1px solid #000 !important;\r\n    }\r\n\r\n    * {\r\n        overflow: visible !important;\r\n    }\r\n    \r\n    /* Watermark styling */\r\n    .watermark {\r\n        position: fixed;\r\n        top: 50%;\r\n        left: 50%;\r\n        transform: translate(-50%, -50%);\r\n        opacity: 0.2; /* 20% visibility */\r\n        z-index: 0;\r\n        font-size: 120px;\r\n        color: #2d3436;\r\n        font-weight: 700;\r\n        text-transform: uppercase;\r\n        white-space: nowrap;\r\n        pointer-events: none;\r\n        user-select: none;\r\n    }\r\n\r\n    /* Ensure all main content stays above watermark */\r\n    .content {\r\n        position: relative;\r\n        z-index: 1;\r\n    }\r\n}\r\n\r\n/* Watermark styling */\r\n    .watermark {\r\n        position: fixed;\r\n        top: 50%;\r\n        left: 50%;\r\n        transform: translate(-50%, -50%);\r\n        opacity: 0.2; /* 20% visibility */\r\n        z-index: 0;\r\n        font-size: 120px;\r\n        color: #2d3436;\r\n        font-weight: 700;\r\n        text-transform: uppercase;\r\n        white-space: nowrap;\r\n        pointer-events: none;\r\n        user-select: none;\r\n    }\r\n\r\n    /* Ensure all main content stays above watermark */\r\n    .content {\r\n        position: relative;\r\n        z-index: 1;\r\n    }",
