            "reqd": 1
        },
        {
            "fieldname": "section_break_thresholds",
            "fieldtype": "Section Break",
            "label": "Thresholds",
            "depends_on": "eval:['Late Login', 'Early Exit', 'Daily Log Submission'].includes(doc.event_type)"
        },
        {
            "fieldname": "late_login_after",
            "fieldtype": "Time",
            "label": "Late Login After (Time)",
            "description": "Trigger evaluation if login is after this time.",
            "depends_on": "eval:doc.event_type == 'Late Login'"
        },
        {
            "fieldname": "early_exit_before",
            "fieldtype": "Time",
            "label": "Early Exit Before (Time)",
            "description": "Trigger evaluation if logout is before this time.",
            "depends_on": "eval:doc.event_type == 'Early Exit'"
        },
        {
            "fieldname": "break_duration_after",
            "fieldtype": "Float",
            "label": "Break Duration After (Hours)",
            "description": "Optional: Trigger evaluation if total break hours exceed this value. If empty, triggers on every log submission.",
            "depends_on": "eval:doc.event_type == 'Daily Log Submission'"
        },
        {
            "fieldname": "specific_day",
            "fieldtype": "Select",
            "label": "Specific Day",
            "options": "Monday\nTuesday\nWednesday\nThursday\nFriday\nSaturday\nSunday",
            "depends_on": "eval:doc.event_type == 'Specific Day Leave'"
        },
        {
            "fieldname": "specific_date",
            "fieldtype": "Date",
            "label": "Specific Date",
